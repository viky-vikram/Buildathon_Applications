{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Daybook: Install Dependencies",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Daybook: Seed Database and Excel",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m backend.app.seed",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Daybook: Run API",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Daybook: Run Streamlit UI",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m streamlit run frontend/streamlit_app.py --server.port 8501",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Daybook: Run Tests",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m unittest discover -s tests",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
